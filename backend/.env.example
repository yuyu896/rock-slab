# Django
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=rock_slab.settings.production
ALLOWED_HOSTS=qhpanpan.top,www.qhpanpan.top
CSRF_TRUSTED_ORIGINS=https://qhpanpan.top,https://www.qhpanpan.top

# SSL 重定向 —— Nginx 已处理，这里设 False，避免健康检查被 301 卡住
SECURE_SSL_REDIRECT=False

# Database (PostgreSQL)
DATABASE_URL=postgresql://rock_slab_user:your-password@localhost:5432/rock_slab

# Redis
REDIS_URL=redis://localhost:6379/1

# Server port
PORT=8002

# Gunicorn（可选，默认按 CPU 自动计算）
# GUNICORN_WORKERS=5
# GUNICORN_THREADS=2
